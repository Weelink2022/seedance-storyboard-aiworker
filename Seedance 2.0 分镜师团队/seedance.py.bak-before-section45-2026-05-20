EPISODE_PATTERN = re.compile(r"(ep\d{2})", re.IGNORECASE)
BUSINESS_PASS_PATTERN = re.compile(r"业务审核：\s*PASS")
COMPLIANCE_PASS_PATTERN = re.compile(r"合规审核：\s*PASS")
# §38 (2026-05-13): art-designer 输出从 2 块 (character+scene) 升级到 3 块 (+prop)
SECTION_PATTERN = re.compile(
    # 2026-05-10 §23.7: 边界标记容错 2-4 个 ">"。
    # DeepSeek 实测会输出 "<<<CHARACTER_PROMPTS>>"（仅 2 个 >），Gemini/豆包 是 3 个 >。
    # §38: PROP_PROMPTS 块可选(老 LLM 输出可能缺，缺时 prop_content=''，不报错)
    r"<<<CHARACTER_PROMPTS>{2,4}\s*(.*?)\s*<<<SCENE_PROMPTS>{2,4}\s*(.*?)"
    r"(?:\s*<<<PROP_PROMPTS>{2,4}\s*(.*))?\Z",
    re.DOTALL,
)


# §38 (2026-05-13): 产物 schema 版本表。SKILL/template 升级 → 把对应 version 加 1
# stage_is_current() 看 frontmatter.schema_version < 这里的值就触发重跑。
SCHEMA_VERSIONS = {
    "director":  1,  # outputs/<ep>/01-director-analysis.md
    "character": 2,  # assets/character-prompts.md (§36 加音色垫词后是 2)
    "scene":     1,  # assets/scene-prompts.md
    "prop":      1,  # assets/prop-prompts.md (§37 新增)
    "storyboard":1,  # outputs/<ep>/02-seedance-prompts.md
}


def compute_skill_hash(*paths: Path) -> str:
    """sha1(concat of file contents). 跳过不存在的文件。"""
    h = hashlib.sha1()
    for p in paths:
        if p.is_file():
            h.update(p.read_bytes())
        elif p.is_dir():
            for f in sorted(p.rglob("*.md")):
                h.update(f.read_bytes())
    return h.hexdigest()[:16]


def render_frontmatter(*, schema_version: int, skill_hash: str, stage: str, episode: str) -> str:
    """§38: 产物 md 顶部 YAML frontmatter。"""
    ts = datetime.datetime.now(datetime.timezone.utc).astimezone().isoformat(timespec="seconds")
    return (
        "---\n"
        f"schema_version: {schema_version}\n"
        f"skill_hash: {skill_hash}\n"
        f"generated_at: {ts}\n"
        f"generator: seedance.py\n"
        f"stage: {stage}\n"
        f"episode: {episode}\n"
        "---\n\n"
    )


def strip_frontmatter(content: str) -> str:
    """剥除 frontmatter (--- ... --- 头部)，返回正文。无 frontmatter 时原样返回。"""
    if content.startswith("---\n"):
        end = content.find("\n---\n", 4)
        if end > 0:
            return content[end + 5:].lstrip()
    return content

