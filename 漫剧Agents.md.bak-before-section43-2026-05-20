function ai_series_ocf_update_task(int $task_id, array $fields): void
{
    // 调用方未显式传 started_at / finished_at 时，自动拍心跳（仅 running 状态）
    if (!array_key_exists('started_at', $fields) && !array_key_exists('finished_at', $fields)) {
